@model IEnumerable<CAT.AID.Models.Candidate>

@{
    ViewBag.Title = "Candidates";
}

<div class="container mt-4 mb-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2 class="fw-bold text-primary">
            👤 Candidates
        </h2>

        <a class="btn btn-success shadow-sm px-4"
           href="@Url.Action("Create", "Candidates")">

            ➕ Add Candidate

        </a>

    </div>



    <!-- CARD -->
    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body">


            @if (!Model.Any())
            {

                <div class="text-center p-5 text-muted">

                    <h5>No candidates available</h5>

                    <p class="small">
                        Click Add Candidate to create profile
                    </p>

                </div>

            }
            else
            {

                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="bg-dark text-white">

                            <tr>

                                <th class="ps-4" style="width:90px;">
                                    Photo
                                </th>

                                <th>
                                    Name & Disability
                                </th>

                                <th>
                                    Location
                                </th>

                                <th style="width:120px;">
                                    Status
                                </th>

                                <th style="width:160px;">
                                    Actions
                                </th>

                            </tr>

                        </thead>



                        <tbody>

                            @foreach (var c in Model)
                            {

                                var age = DateTime.Now.Year - c.DOB.Year;

                                if (c.DOB.Date > DateTime.Now.AddYears(-age))
                                    age--;


                                <tr>


                                    <!-- PHOTO -->
                                    <td class="ps-4">

                                        <img src="@c.PhotoFilePath"
                                             onerror="this.src='/images/no-photo.png'"

                                             class="profile-img" />

                                    </td>



                                    <!-- NAME -->
                                    <td>

                                        <div class="fw-bold">

                                            @c.FullName

                                        </div>


                                        <div class="text-muted small">

                                            @c.DisabilityType • @age yrs

                                        </div>

                                    </td>



                                    <!-- LOCATION -->
                                    <td>

                                        <span class="text-muted"
                                              title="@c.CommunicationAddress">

                                            @((c.CommunicationAddress?.Length > 45)

                                                ? c.CommunicationAddress.Substring(0, 45) + "..."

                                                : c.CommunicationAddress)

                                        </span>

                                    </td>



                                    <!-- STATUS -->
                                    <td>

                                        @if (!c.IsArchived)
                                        {

                                            <span class="badge bg-success px-3 py-2">

                                                ✔ Active

                                            </span>

                                        }
                                        else
                                        {

                                            <span class="badge bg-danger px-3 py-2">

                                                🚫 Blocked

                                            </span>

                                        }

                                    </td>



                                    <!-- ACTIONS -->
                                    <td>

                                        <div class="dropdown">

                                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                                    data-bs-toggle="dropdown"
                                                    data-bs-boundary="viewport">

                                                Actions

                                            </button>


                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">

                                                <li>

                                                    <a class="dropdown-item"
                                                       href="@Url.Action("Edit", new { id = c.Id })">

                                                        ✏ Edit

                                                    </a>

                                                </li>


                                                <li>

                                                    <a class="dropdown-item"
                                                       href="@Url.Action("Details", new { id = c.Id })">

                                                        👁 View Profile

                                                    </a>

                                                </li>



                                                <li>

                                                    <a class="dropdown-item"
                                                       href="@Url.Action("Assign", new { id = c.Id })">

                                                        📝 Assign Assessment

                                                    </a>

                                                </li>



                                                <li>

                                                    <hr class="dropdown-divider">

                                                </li>



                                                @if (!c.IsArchived)
                                                {

                                                    <li>

                                                        <a class="dropdown-item text-warning"
                                                           href="@Url.Action("Archive", new { id = c.Id })">

                                                            🚫 Block Candidate

                                                        </a>

                                                    </li>

                                                }
                                                else
                                                {

                                                    <li>

                                                        <a class="dropdown-item text-success"
                                                           href="@Url.Action("Unarchive", new { id = c.Id })">

                                                            ♻ Restore Candidate

                                                        </a>

                                                    </li>

                                                }


                                            </ul>

                                        </div>

                                    </td>


                                </tr>

                            }


                        </tbody>


                    </table>

                </div>

            }

        </div>

    </div>

</div>



<style>

/* allow dropdown outside card */
.card
{
    overflow:visible !important;
}


/* profile image */
.profile-img
{
    width:55px;
    height:65px;
    object-fit:cover;
    border-radius:10px;
    border:2px solid #e9ecef;
    background:#f8f9fa;
}


/* hover effect */
.table tbody tr:hover
{
    background:#f8f9fa;
    transition:.2s;
}


/* dropdown visibility fix */
.dropdown-menu
{
    z-index:5000 !important;
}


/* badge style */
.badge
{
    border-radius:8px;
    font-size:.8rem;
}


/* button style */
.btn
{
    border-radius:8px;
}

</style>
