@model IEnumerable<CAT.AID.Models.Candidate>

@{
    ViewBag.Title = "Candidates";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">

    <h2 class="fw-bold text-primary mb-0">
        👤 Candidates
    </h2>

    <a class="btn btn-success"
       href="@Url.Action("Create","Candidates")">

        ➕ Add Candidate

    </a>

</div>



@if (!Model.Any())
{

    <div class="alert alert-info text-center">

        No candidates available

    </div>

}
else
{

<!-- DESKTOP TABLE -->
<div class="table-responsive d-none d-md-block">

<table class="table table-hover align-middle">

<thead>

<tr>

<th style="width:70px;">Photo</th>

<th>Name</th>

<th>Location</th>

<th>Status</th>

<th style="width:150px;">Actions</th>

</tr>

</thead>



<tbody>

@foreach (var c in Model)
{

var age = DateTime.Now.Year - c.DOB.Year;
if (c.DOB.Date > DateTime.Now.AddYears(-age)) age--;


<tr>

<td>

<img src="@c.PhotoFilePath"
onerror="this.src='/images/no-photo.png'"
class="candidate-img"/>

</td>



<td>

<div class="fw-bold">@c.FullName</div>

<div class="small text-muted">
@c.DisabilityType • @age yrs
</div>

</td>



<td>

<span class="text-muted">

@((c.CommunicationAddress?.Length > 40)
? c.CommunicationAddress.Substring(0,40)+"..."
: c.CommunicationAddress)

</span>

</td>



<td>

@if (!c.IsArchived)
{
<span class="badge bg-success">Active</span>
}
else
{
<span class="badge bg-danger">Blocked</span>
}

</td>



<td>

<div class="dropdown">

<button class="btn btn-outline-secondary btn-sm dropdown-toggle"
data-bs-toggle="dropdown"
data-bs-boundary="viewport">

Actions

</button>

<ul class="dropdown-menu dropdown-menu-end">

<li>
<a class="dropdown-item"
href="@Url.Action("Edit", new { id = c.Id })">
Edit
</a>
</li>

<li>
<a class="dropdown-item"
href="@Url.Action("Details", new { id = c.Id })">
View Profile
</a>
</li>

<li>
<a class="dropdown-item"
href="@Url.Action("Assign", new { id = c.Id })">
Assign Assessment
</a>
</li>

<li><hr></li>

@if (!c.IsArchived)
{
<li>
<a class="dropdown-item text-warning"
href="@Url.Action("Archive", new { id = c.Id })">
Block
</a>
</li>
}
else
{
<li>
<a class="dropdown-item text-success"
href="@Url.Action("Unarchive", new { id = c.Id })">
Restore
</a>
</li>
}

</ul>

</div>

</td>

</tr>

}

</tbody>

</table>

</div>



<!-- MOBILE CARD VIEW -->
<div class="d-md-none">

@foreach (var c in Model)
{

var age = DateTime.Now.Year - c.DOB.Year;
if (c.DOB.Date > DateTime.Now.AddYears(-age)) age--;


<div class="card mb-3 shadow-sm border-0">

<div class="card-body">

<div class="d-flex gap-3">

<img src="@c.PhotoFilePath"
onerror="this.src='/images/no-photo.png'"
class="candidate-img"/>


<div class="flex-grow-1">

<div class="fw-bold">

@c.FullName

</div>


<div class="small text-muted">

@c.DisabilityType • @age yrs

</div>


<div class="small mt-1">

📍 @c.CommunicationAddress

</div>


<div class="mt-2">

@if (!c.IsArchived)
{
<span class="badge bg-success">Active</span>
}
else
{
<span class="badge bg-danger">Blocked</span>
}

</div>


<div class="mt-2">

<div class="dropdown">

<button class="btn btn-outline-secondary btn-sm w-100 dropdown-toggle"
data-bs-toggle="dropdown"
data-bs-boundary="viewport">

Actions

</button>

<ul class="dropdown-menu w-100">

<li>
<a class="dropdown-item"
href="@Url.Action("Edit", new { id = c.Id })">
Edit
</a>
</li>

<li>
<a class="dropdown-item"
href="@Url.Action("Details", new { id = c.Id })">
View Profile
</a>
</li>

<li>
<a class="dropdown-item"
href="@Url.Action("Assign", new { id = c.Id })">
Assign Assessment
</a>
</li>

@if (!c.IsArchived)
{
<li>
<a class="dropdown-item text-warning"
href="@Url.Action("Archive", new { id = c.Id })">
Block
</a>
</li>
}
else
{
<li>
<a class="dropdown-item text-success"
href="@Url.Action("Unarchive", new { id = c.Id })">
Restore
</a>
</li>
}

</ul>

</div>

</div>

</div>

</div>

</div>

</div>

}

</div>

}



<style>

.candidate-img
{
width:60px;
height:60px;
object-fit:cover;
border-radius:10px;
border:1px solid #e5e7eb;
background:#f1f5f9;
}

.dropdown-menu
{
z-index:5000;
}

</style>
