@using Microsoft.AspNetCore.Identity
@using CAT.AID.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html>

<head>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>

        /* LOGIN PAGE */

        .login-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 50px;
            flex-wrap: wrap;
        }

        /* LOGO */

        .login-logo {
            height: 380px;
            object-fit: contain;
        }

        /* CARD */

        .login-card {
            width: 360px;
            background: white;
            padding: 35px;
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,.08);
        }

        /* TITLE */

        .login-title {
            color: #4B3504;
            font-weight: 700;
            margin-bottom: 20px;
            text-align: center;
        }

        /* INPUT */

        .form-control {
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #e6dcc5;
        }

            .form-control:focus {
                border-color: #4B3504;
                box-shadow: 0 0 0 3px rgba(75,53,4,0.15);
            }

        /* BUTTON */

        .btn-login {
            background: linear-gradient(90deg,#4B3504,#6a4a08);
            border: none;
            color: white;
            padding: 12px;
            width: 100%;
            border-radius: 10px;
            font-weight: 600;
        }

        /* LABEL */

        .form-label {
            font-weight: 600;
            font-size: 14px;
            color: #4B3504;
        }

        /* MOBILE */

        @@media(max - width:768px) {
            .login-wrapper

        {
            flex-direction: column;
            gap: 25px;
        }

        .login-logo {
            height: 160px;
        }

        }
    </style>

</head>

<body>

    <div class="login-wrapper">

        <!-- LEFT LOGO -->

        <img src="/Images/nimhnew1.png" class="login-logo" />

        <!-- LOGIN FORM -->

        <div class="login-card">

            <h3 class="login-title">

                Login

            </h3>

            <form method="post" asp-controller="Account" asp-action="Login">

                <div class="mb-3">

                    <label class="form-label">

                        Username

                    </label>

                    <input name="Email"
                           class="form-control"
                           placeholder="Enter username"
                           required />

                </div>


                <div class="mb-3">

                    <label class="form-label">

                        Password

                    </label>

                    <input type="password"
                           name="Password"
                           class="form-control"
                           placeholder="Enter password"
                           required />

                </div>


                <div class="mb-3 form-check">

                    <input type="checkbox"
                           name="RememberMe"
                           class="form-check-input" />

                    <label class="form-check-label">

                        Remember me

                    </label>

                </div>


                <button type="submit"
                        class="btn-login">

                    Login

                </button>

            </form>

        </div>

    </div>


    <div class="footer">

        © @DateTime.Now.Year NIEPID
        Manovikas Nagar, Secunderabad – 500009

    </div>

</body>

</html>
