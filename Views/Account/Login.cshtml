@using Microsoft.AspNetCore.Identity
@using CAT.AID.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>

<html>

<head>

<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>


<style>

/* page */

body
{
background:#f4f7fb;
font-family:'Segoe UI',system-ui;
}


/* layout */

.login-wrapper
{
min-height:90vh;
display:flex;
align-items:center;
justify-content:center;
gap:50px;
flex-wrap:wrap;
padding:20px;
}


/* logo */

.login-logo
{
height:320px;
max-width:100%;
object-fit:contain;
}


/* card */

.login-card
{
width:100%;
max-width:380px;
background:white;
padding:35px;
border-radius:18px;
box-shadow:0 15px 40px rgba(0,0,0,.08);
}


/* title */

.login-title
{
text-align:center;
font-weight:700;
color:#0f172a;
margin-bottom:25px;
}


/* inputs */

.form-control
{
border-radius:10px;
padding:12px;
border:1px solid #e5e7eb;
}

.form-control:focus
{
border-color:#2563eb;
box-shadow:0 0 0 3px rgba(37,99,235,.15);
}


/* button */

.btn-login
{
background:linear-gradient(90deg,#2563eb,#0ea5e9);
border:none;
color:white;
padding:12px;
width:100%;
border-radius:10px;
font-weight:600;
transition:.2s;
}

.btn-login:hover
{
opacity:.9;
}


/* footer */

.footer
{
text-align:center;
font-size:13px;
margin-top:20px;
color:#64748b;
}


/* mobile */

@media(max-width:768px)
{

.login-wrapper
{
flex-direction:column;
gap:20px;
}

.login-logo
{
height:150px;
}

.login-card
{
padding:25px;
}

}

</style>

</head>



<body>



<div class="login-wrapper">

<!-- logo -->

<img src="/Images/nimhnew1.png"
class="login-logo"/>



<!-- form -->

<div class="login-card">


<h3 class="login-title">

CVAT Login

</h3>


<form method="post"
asp-controller="Account"
asp-action="Login">


<div class="mb-3">

<label class="form-label">

Email / Username

</label>


<input name="Email"
class="form-control"
placeholder="Enter email"
required />

</div>



<div class="mb-3">

<label class="form-label">

Password

</label>


<input type="password"
name="Password"
class="form-control"
placeholder="Enter password"
required />

</div>



<div class="mb-3 form-check">

<input type="checkbox"
name="RememberMe"
class="form-check-input"/>

<label class="form-check-label">

Remember me

</label>

</div>



<button type="submit"
class="btn-login">

Login

</button>


</form>


</div>



</div>



<div class="footer">

© @DateTime.Now.Year NIEPID
Manovikas Nagar, Secunderabad – 500009

</div>



</body>

</html>
