@using CAT.AID.Models.DTO
@model DashboardDTO

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<h2 class="title">Dashboard</h2>


<div class="grid">

    <div class="card total">
        <h3>Total</h3>
        <h1>@Model.TotalAssessments</h1>
    </div>

    <div class="card submitted">
        <h3>Submitted</h3>
        <h1>@Model.SubmittedCount</h1>
    </div>

    <div class="card pending">
        <h3>Pending</h3>
        <h1>@Model.PendingCount</h1>
    </div>

    <div class="card approved">
        <h3>Approved</h3>
        <h1>@Model.ApprovedCount</h1>
    </div>

</div>



<div class="chart">
    <h3>Monthly Trend</h3>
    <div class="chart-wrapper">
        <canvas id="trendChart"></canvas>
    </div>
</div>


<div class="chart">
    <h3>Assessor Performance</h3>
    <div class="chart-wrapper">
        <canvas id="assessorChart"></canvas>
    </div>
</div>


<div class="chart">
    <h3>Recent Activity</h3>
    <div class="chart-wrapper">
        <canvas id="recentChart"></canvas>
    </div>
</div>



<div class="chart">
    <h3>Low Domains</h3>

    @if (Model.LowDomains.Count == 0)
    {
        <p class="success">All domains performing well</p>
    }
    else
    {
        <ul class="low-list">

            @foreach (var d in Model.LowDomains)
            {
                <li>
                    <span>@d.Key</span>
                    <strong>@d.Value.ToString("0")%</strong>
                </li>
            }

        </ul>
    }

</div>



<style>

.title{
    margin-bottom:20px;
    font-weight:600;
}


/* responsive grid */

.grid {
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:15px;
    margin-bottom:30px;
}


/* cards */

.card {
    background:white;
    padding:20px;
    border-radius:14px;
    box-shadow:0 4px 12px rgba(0,0,0,.08);
    text-align:center;
    transition:.2s;
}

.card:hover{
    transform:translateY(-3px);
}


/* card colors */

.total{
border-left:6px solid #0d6efd;
}

.submitted{
border-left:6px solid #198754;
}

.pending{
border-left:6px solid #ffc107;
}

.approved{
border-left:6px solid #20c997;
}



/* charts */

.chart {
    background:white;
    padding:20px;
    margin-bottom:25px;
    border-radius:14px;
    box-shadow:0 4px 12px rgba(0,0,0,.08);
}


.chart-wrapper{
    position:relative;
    width:100%;
    height:300px;
}



/* low domain list */

.low-list{
list-style:none;
padding:0;
}

.low-list li{
display:flex;
justify-content:space-between;
padding:8px 0;
border-bottom:1px solid #eee;
}


.success{
color:green;
font-weight:600;
}



/* tablet */

@media (max-width:1024px){

.grid{
grid-template-columns:repeat(2,1fr);
}

.chart-wrapper{
height:260px;
}

}



/* mobile */

@media (max-width:600px){

.grid{
grid-template-columns:1fr;
}

.card{
padding:16px;
}

.chart-wrapper{
height:240px;
}

h1{
font-size:26px;
}

h3{
font-size:16px;
}

}

</style>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


<script>

const commonOptions = {
responsive:true,
maintainAspectRatio:false
};


new Chart(document.getElementById("trendChart"),{

type:'line',

data:{
labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels)),

datasets:[{
label:'Assessments',
data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthCounts)),
tension:0.3
}]
},

options:commonOptions

});



new Chart(document.getElementById("assessorChart"),{

type:'bar',

data:{
labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorNames)),

datasets:[{
label:'Count',
data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorCounts))
}]
},

options:commonOptions

});



new Chart(document.getElementById("recentChart"),{

type:'line',

data:{
labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentDates)),

datasets:[{
label:'Daily Activity',
data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentCounts)),
tension:0.3
}]
},

options:commonOptions

});

</script>
