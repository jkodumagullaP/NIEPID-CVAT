@using CAT.AID.Models.DTO
@model DashboardDTO

<h2 class="fw-bold mb-3">
📊 Dashboard
</h2>


<!-- METRICS -->
<div class="row g-3 mb-3">

<div class="col-6 col-md-3">

<div class="metric-card border-primary">

<div class="metric-title">
Total
</div>

<div class="metric-value">

@Model.TotalAssessments

</div>

</div>

</div>



<div class="col-6 col-md-3">

<div class="metric-card border-success">

<div class="metric-title">
Submitted
</div>

<div class="metric-value">

@Model.SubmittedCount

</div>

</div>

</div>



<div class="col-6 col-md-3">

<div class="metric-card border-warning">

<div class="metric-title">
Pending
</div>

<div class="metric-value">

@Model.PendingCount

</div>

</div>

</div>



<div class="col-6 col-md-3">

<div class="metric-card border-info">

<div class="metric-title">
Approved
</div>

<div class="metric-value">

@Model.ApprovedCount

</div>

</div>

</div>

</div>



<!-- CHARTS -->
<div class="row g-3">

<div class="col-12 col-lg-6">

<div class="chart-card">

<h6 class="chart-title">

Monthly Trend

</h6>

<div class="chart-box">

<canvas id="trendChart"></canvas>

</div>

</div>

</div>



<div class="col-12 col-lg-6">

<div class="chart-card">

<h6 class="chart-title">

Assessor Performance

</h6>

<div class="chart-box">

<canvas id="assessorChart"></canvas>

</div>

</div>

</div>



<div class="col-12">

<div class="chart-card">

<h6 class="chart-title">

Recent Activity

</h6>

<div class="chart-box">

<canvas id="recentChart"></canvas>

</div>

</div>

</div>



<div class="col-12 col-lg-6">

<div class="chart-card">

<h6 class="chart-title">

Low Domains

</h6>


@if (Model.LowDomains.Count == 0)
{

<div class="text-success">

All domains performing well

</div>

}
else
{

<ul class="list-group">

@foreach (var d in Model.LowDomains)
{

<li class="list-group-item d-flex justify-content-between">

<span>

@d.Key

</span>

<span class="fw-bold text-danger">

@d.Value.ToString("0")%

</span>

</li>

}

</ul>

}

</div>

</div>

</div>



<style>

.metric-card
{
background:white;
padding:16px;
border-radius:12px;
box-shadow:0 4px 12px rgba(0,0,0,.08);
border-left:5px solid;
text-align:center;
height:100%;
}

.metric-title
{
font-size:14px;
color:#64748b;
}

.metric-value
{
font-size:28px;
font-weight:700;
margin-top:5px;
}


.chart-card
{
background:white;
padding:18px;
border-radius:12px;
box-shadow:0 4px 12px rgba(0,0,0,.08);
}


.chart-title
{
font-weight:600;
margin-bottom:10px;
}


.chart-box
{
position:relative;
width:100%;
height:280px;
}


/* tablet */

@media(max-width:992px)
{

.chart-box
{
height:260px;
}

}


/* mobile */

@media(max-width:576px)
{

.metric-value
{
font-size:22px;
}

.chart-box
{
height:240px;
}

}

</style>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const commonOptions = {

responsive:true,

maintainAspectRatio:false

};



new Chart(document.getElementById("trendChart"),{

type:'line',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels)),

datasets:[{

label:'Assessments',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthCounts)),

tension:0.3

}]

},

options:commonOptions

});



new Chart(document.getElementById("assessorChart"),{

type:'bar',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorNames)),

datasets:[{

label:'Count',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorCounts))

}]

},

options:commonOptions

});



new Chart(document.getElementById("recentChart"),{

type:'line',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentDates)),

datasets:[{

label:'Daily Activity',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentCounts)),

tension:0.3

}]

},

options:commonOptions

});

</script>
