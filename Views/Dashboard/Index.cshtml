@using CAT.AID.Models.DTO
@model DashboardDTO

<h2 class="page-title">
    Dashboard
</h2>


<!-- KPI CARDS -->

<div class="grid">

    <div class="card kpi">
        <div class="kpi-title">Total</div>
        <div class="kpi-value">@Model.TotalAssessments</div>
    </div>

    <div class="card kpi">
        <div class="kpi-title">Submitted</div>
        <div class="kpi-value">@Model.SubmittedCount</div>
    </div>

    <div class="card kpi">
        <div class="kpi-title">Pending</div>
        <div class="kpi-value">@Model.PendingCount</div>
    </div>

    <div class="card kpi">
        <div class="kpi-title">Approved</div>
        <div class="kpi-value">@Model.ApprovedCount</div>
    </div>

</div>



<!-- CHARTS -->

<div class="chart">
    <h3>Monthly Trend</h3>
    <canvas id="trendChart"></canvas>
</div>


<div class="chart">
    <h3>Assessor Performance</h3>
    <canvas id="assessorChart"></canvas>
</div>


<div class="chart">
    <h3>Recent Activity</h3>
    <canvas id="recentChart"></canvas>
</div>


<div class="chart">
    <h3>Low Domains</h3>

    @if (Model.LowDomains.Count == 0)
    {
        <p class="text-success">All domains performing well</p>
    }
    else
    {
        <ul class="low-list">

            @foreach (var d in Model.LowDomains)
            {
                <li>
                    <span>@d.Key</span>
                    <span class="percent">@d.Value.ToString("0")%</span>
                </li>
            }

        </ul>
    }

</div>



<style>

.page-title{
font-weight:700;
margin-bottom:25px;
color:#0f172a;
}


/* KPI GRID */

.grid{

display:grid;
grid-template-columns:repeat(4,1fr);
gap:18px;
margin-bottom:30px;

}


/* CARD */

.card{

background:white;
padding:22px;
border-radius:14px;
box-shadow:0 8px 22px rgba(0,0,0,.06);

}


/* KPI STYLE */

.kpi{

text-align:center;
background:linear-gradient(180deg,#ffffff,#f8fbff);
border-top:4px solid #0b5ed7;

}


.kpi-title{

font-size:14px;
color:#64748b;
margin-bottom:5px;

}


.kpi-value{

font-size:30px;
font-weight:700;
color:#0b5ed7;

}


/* CHART BOX */

.chart{

background:white;
padding:22px;
margin-bottom:25px;
border-radius:14px;
box-shadow:0 8px 22px rgba(0,0,0,.05);

}


.chart h3{

margin-bottom:15px;
font-size:18px;

}


/* LOW DOMAIN LIST */

.low-list{

list-style:none;
padding:0;
margin:0;

}


.low-list li{

display:flex;
justify-content:space-between;
padding:8px 0;
border-bottom:1px solid #f1f5f9;

}


.percent{

font-weight:600;
color:#dc2626;

}


/* RESPONSIVE */

@@media(max-width:1100px){

.grid{

grid-template-columns:repeat(2,1fr);

}

}


@@media(max-width:600px){

.grid{

grid-template-columns:1fr;

}

.kpi-value{

font-size:26px;

}

}

</style>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>



<script>

new Chart(document.getElementById("trendChart"),{

type:'line',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels)),

datasets:[{

label:'Assessments',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthCounts)),

borderWidth:3,
tension:.3

}]

},

options:{

responsive:true,
plugins:{legend:{display:false}}

}

});




new Chart(document.getElementById("assessorChart"),{

type:'bar',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorNames)),

datasets:[{

label:'Count',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessorCounts)),

borderWidth:1

}]

},

options:{

responsive:true,
plugins:{legend:{display:false}}

}

});




new Chart(document.getElementById("recentChart"),{

type:'line',

data:{

labels:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentDates)),

datasets:[{

label:'Daily Activity',

data:@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RecentCounts)),

borderWidth:3,
tension:.3

}]

},

options:{

responsive:true,
plugins:{legend:{display:false}}

}

});

</script>
