@using CAT.AID.Models.DTO
@model List<AssessmentSection>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2 class="fw-bold text-primary">
            📚 Question Bank
        </h2>

        <div class="d-flex gap-2 flex-wrap">

            <a href="/QuestionBank/Edit"
               class="btn btn-success shadow-sm px-3">
                ➕ Add Question
            </a>

            <form method="post"
                  enctype="multipart/form-data"
                  asp-action="Upload"
                  class="d-flex gap-2">

                <input type="file"
                       name="file"
                       class="form-control form-control-sm"
                       required />

                <button class="btn btn-primary shadow-sm">
                    ⬆ Import
                </button>

            </form>

            <a href="/QuestionBank/Download"
               class="btn btn-outline-primary shadow-sm">
                ⬇ Export
            </a>

        </div>

    </div>


    <!-- SECTIONS -->
    @foreach (var sec in Model)
    {

        <div class="card border-0 shadow-lg rounded-4 mb-4">

            <!-- SECTION HEADER -->
            <div class="card-header bg-dark text-white rounded-top-4">

                <div class="d-flex justify-content-between align-items-center">

                    <div class="fw-bold fs-5">
                        📂 @sec.Category
                    </div>

                    <span class="badge bg-light text-dark">
                        @sec.Questions.Count Questions
                    </span>

                </div>

            </div>


            <!-- TABLE -->
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th class="ps-4" style="width:80px;">ID</th>

                            <th>Question</th>

                            <th style="width:140px;">Correct</th>

                            <th style="width:120px;">Weight</th>

                            <th style="width:200px;" class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>


                    <tbody>

                        @foreach (var q in sec.Questions)
                        {

                            <tr>

                                <!-- ID -->
                                <td class="fw-bold ps-4 text-primary">
                                    #@q.Id
                                </td>


                                <!-- Question -->
                                <td>
                                    @q.Text
                                </td>


                                <!-- Correct -->
                                <td>

                                    @if (!string.IsNullOrWhiteSpace(q.Correct))
                                    {
                                        <span class="badge bg-success px-3 py-2">
                                            ✔ @q.Correct
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            —
                                        </span>
                                    }

                                </td>


                                <!-- Weight -->
                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2">
                                        @q.ScoreWeight
                                    </span>
                                </td>


                                <!-- ACTIONS -->
                                <td class="text-center">

                                    <div class="btn-group">

                                        <a href="/QuestionBank/Edit?id=@q.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            ✏ Edit
                                        </a>

                                        <a href="/QuestionBank/Delete/@q.Id"
                                           onclick="return confirm('Delete this question?')"
                                           class="btn btn-sm btn-outline-danger">
                                            🗑 Delete
                                        </a>

                                    </div>

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>

    }

</div>



<style>

.card
{
    background:white;
}

.card-header
{
    border:none;
}

.table tbody tr:hover
{
    background-color:#f8f9fa;
    transition:.2s;
}

.badge
{
    font-size:.8rem;
    border-radius:8px;
}

.btn
{
    border-radius:8px;
}

input[type=file]
{
    border-radius:8px;
}

</style>
