@using CAT.AID.Models.DTO
@model List<AssessmentSection>

<h3 class="fw-bold mb-3 text-brown">

    📚 Question Bank

</h3>

<style>

    /* THEME COLORS */

    :root {
        --navy: #0B2E4F;
        --brown: #4B3504;
        --brown-light: #6a4a08;
        --bg: #f5f7fa;
    }


    /* CARD */

    .glass-box {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        margin-bottom: 20px;
    }


    /* TITLE */

    .text-brown {
        color: var(--brown);
    }


    /* ACTION BAR */

    .action-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }


    /* BUTTON */

    .btn-main {
        background: linear-gradient(135deg,var(--brown),var(--brown-light));
        color: white;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        font-weight: 600;
    }

        .btn-main:hover {
            opacity: .95;
            color: white;
        }


    /* TABLE */

    .table {
        border-radius: 12px;
        overflow: hidden;
        font-size: 14px;
    }


        .table thead {
            background: var(--navy);
            color: white;
        }


        .table tbody tr:hover {
            background: #f8f9fb;
        }


    /* ACTION BUTTONS */

    .action-buttons {
        display: flex;
        gap: 6px;
    }


    /* EDIT */

    .btn-edit {
        background: var(--brown);
        color: white;
        padding: 5px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
    }


    .btn-delete {
        background: #c62828;
        color: white;
        padding: 5px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
    }


    /* MOBILE */

    @@media(max-width:768px) {

        .action-bar {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-buttons {
            flex-direction: column;
        }
    }

</style>



<div class="glass-box">

    <div class="action-bar">


        <a href="/QuestionBank/Edit"
           class="btn btn-main">

            ➕ Add Question

        </a>



        <form method="post"
              enctype="multipart/form-data"
              asp-action="Upload"
              class="d-flex gap-2 flex-wrap">

            <input type="file"
                   name="file"
                   class="form-control"
                   required />


            <button class="btn btn-main">

                ⬆ Import Excel

            </button>


        </form>



        <a href="/QuestionBank/Download"
           class="btn btn-main">

            ⬇ Export Excel

        </a>


    </div>

</div>



@foreach (var sec in Model)

{

    <div class="glass-box">


        <h5 class="fw-bold mb-3 text-brown">

            @sec.Category

        </h5>



        <table class="table table-bordered table-hover">

            <thead>

                <tr>

                    <th style="width:70px">

                        ID

                    </th>

                    <th>

                        Question

                    </th>

                    <th style="width:120px">

                        Correct

                    </th>

                    <th style="width:90px">

                        Weight

                    </th>

                    <th style="width:160px">

                        Actions

                    </th>

                </tr>

            </thead>



            <tbody>

                @foreach (var q in sec.Questions)

                {

                    <tr>


                        <td class="fw-bold">

                            @q.Id

                        </td>


                        <td>

                            @q.Text

                        </td>


                        <td>

                            @(string.IsNullOrWhiteSpace(q.Correct)

                                                ? "-"

                                                : q.Correct)

                </td>


                        <td class="fw-bold">

                            @q.ScoreWeight

                        </td>


                        <td>


                            <div class="action-buttons">


                                <a href="/QuestionBank/Edit?id=@q.Id"
                                   class="btn-edit">

                                    ✏ Edit

                                </a>



                                <a href="/QuestionBank/Delete/@q.Id"
                                   onclick="return confirm('Delete this question?')"
                                   class="btn-delete">

                                    🗑 Delete

                                </a>


                            </div>


                        </td>


                    </tr>

                        }

            </tbody>


        </table>


    </div>

}
