@using CAT.AID.Models
@using CAT.AID.Models.DTO
@using CAT.AID.Web.Models.DTO

@model Assessment

@{
var recommendations = ViewBag.Recommendations as Dictionary<string, List<string>>;
var weakDetails = ViewBag.WeakDetails as Dictionary<string, List<string>>;
var sections = ViewBag.Sections as List<AssessmentSection>;


var saved = string.IsNullOrWhiteSpace(Model.AssessmentResultJson)
    ? new Dictionary<string,string>()
    : System.Text.Json.JsonSerializer.Deserialize<Dictionary<string,string>>(Model.AssessmentResultJson);

var score = string.IsNullOrWhiteSpace(Model.ScoreJson)
    ? new AssessmentScoreDTO()
    : System.Text.Json.JsonSerializer.Deserialize<AssessmentScoreDTO>(Model.ScoreJson);

var candidate = Model.Candidate;


}

<style>

.glass-card{
background:rgba(255,255,255,.75);
backdrop-filter:blur(12px);
border-radius:16px;
padding:20px;
box-shadow:0 10px 28px rgba(0,0,0,.15);
}

.soft-card{
background:#f7f9ff;
border-radius:12px;
padding:16px;
border:1px solid #dce6ff;
box-shadow:0 2px 10px rgba(0,0,0,.05);
}

.metric-box{
border-radius:12px;
padding:12px;
background:rgba(240,248,255,.7);
box-shadow:0 3px 10px rgba(0,0,0,.1);
}

</style>

<h3 class="text-primary fw-bold">
Assessment Result — @candidate.FullName
</h3>

<!-- Candidate Information -->

<div class="card shadow-sm p-3 mb-4">

<h4 class="fw-bold text-primary mb-3">
🧑‍💼 Candidate Information
</h4>

<div class="row">

<div class="col-md-3 text-center">

<img src="@candidate.PhotoFilePath"
class="border rounded"
style="width:140px;height:160px;object-fit:cover;" />

</div>

<div class="col-md-9">

<table class="table table-bordered">

<tr><th>Name</th><td>@candidate.FullName</td></tr>
<tr><th>Gender</th><td>@candidate.Gender</td></tr>
<tr><th>Date of Birth</th><td>@candidate.DOB.ToString("dd-MMM-yyyy")</td></tr>
<tr><th>Education</th><td>@candidate.Education</td></tr>
<tr><th>Marital Status</th><td>@candidate.MaritalStatus</td></tr>

</table>

</div>

</div>

</div>

<!-- Score Metrics -->

@{
double percent = score.MaxScore > 0
? Math.Round(((double)score.TotalScore / score.MaxScore) * 100, 2)
: 0;
}

<div class="metric-box mb-3">

<strong>Total Score:</strong>
@score.TotalScore / @score.MaxScore

  

<strong>Percentage:</strong>
@percent %

</div>

<!-- Charts -->

<div class="row mb-4">

<div class="col-md-6">
<div class="soft-card">
<canvas id="barChart"></canvas>
</div>
</div>

<div class="col-md-6">
<div class="soft-card">
<canvas id="doughnutChart"></canvas>
</div>
</div>

</div>

<hr/>

<h5 class="fw-bold text-primary">
🎯 Recommendations
</h5>

@if(recommendations?.Any()==true)
{
foreach(var r in recommendations)
{

<div class="soft-card mb-2">

<h6 class="fw-bold text-primary">
@r.Key
</h6>

<ul>

@foreach(var rec in r.Value)
{

<li>@rec</li>
}

</ul>

</div>
}
}

<hr/>

<!-- SECTION PERFORMANCE -->

@foreach(var sec in sections)
{

<h5 class="fw-bold text-info mt-4">
@sec.Category
</h5>

<table class="table table-bordered table-sm">

<thead class="table-dark">

<tr>
<th>Q ID</th>
<th>Question</th>
<th>Answer</th>
<th>Score</th>
<th>Evidence</th>
</tr>

</thead>

<tbody>

@foreach(var q in sec.Questions)
{

saved.TryGetValue($"ANS_{q.Id}",out string ans);
saved.TryGetValue($"SCORE_{q.Id}",out string scr);

var files = saved
.Where(x=>x.Key.StartsWith($"FILE_{q.Id}"))
.Select(x=>x.Value)
.ToList();

<tr>

<td>@q.Id</td>

<td>@q.Text</td>

<td>@(ans ?? "-")</td>

<td>@(scr ?? "0")</td>

<td>

@if(files.Any())
{
foreach(var f in files)
{

<div>
<a href="/uploads/@f"
target="_blank"
class="btn btn-outline-primary btn-sm">
📎 View
</a>
</div>
}
}
else
{
<span class="text-muted">—</span>
}

</td>

</tr>

}

</tbody>

</table>

<!-- SECTION COMMENT -->


string sectionCommentKey = $"SECTION_COMMENT_{sec.Id}";
saved.TryGetValue(sectionCommentKey,out string secComment);


@if(!string.IsNullOrEmpty(secComment))
{

<div class="alert alert-secondary">

<strong>Section Comment:</strong>

<p>@secComment</p>

</div>
}

}

<hr/>

<div class="alert alert-secondary">

<h6 class="fw-bold">
📝 Overall Summary
</h6>

<p>@ViewBag.Summary</p>

</div>

<div class="text-end mt-3">

<form method="post"
action="/Assessments/ExportReportPdf/@Model.Id">

<input type="hidden"
id="barChartImage"
name="barChartImage"/>

<input type="hidden"
id="doughnutChartImage"
name="doughnutChartImage"/>

<button class="btn btn-primary">

📄 Download PDF

</button>

</form>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const labels =
@Html.Raw(Json.Serialize(score.SectionScores.Keys));

const values =
@Html.Raw(Json.Serialize(score.SectionScores.Values));

const total=@score.TotalScore;
const remaining=@score.MaxScore-total;

new Chart(document.getElementById("barChart"),{

type:"bar",

data:{
labels,
datasets:[{
label:"Section Score",
data:values,
backgroundColor:"#1F5CAA"
}]
}

});


new Chart(document.getElementById("doughnutChart"),{

type:"doughnut",

data:{
labels:["Achieved","Remaining"],
datasets:[{
data:[total,remaining],
backgroundColor:["#003366","#9bbde6"]
}]
}

});

</script>
