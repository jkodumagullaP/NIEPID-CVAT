@using CAT.AID.Models
@using CAT.AID.Models.DTO
@using CAT.AID.Web.Models.DTO

@model Assessment

@{
var recommendations = ViewBag.Recommendations as Dictionary<string,List<string>>;
var sections = ViewBag.Sections as List<AssessmentSection>;

var saved =
string.IsNullOrWhiteSpace(Model.AssessmentResultJson)
? new Dictionary<string,string>()
: System.Text.Json.JsonSerializer.Deserialize<Dictionary<string,string>>
(Model.AssessmentResultJson);

var score =
string.IsNullOrWhiteSpace(Model.ScoreJson)
? new AssessmentScoreDTO()
: System.Text.Json.JsonSerializer.Deserialize<AssessmentScoreDTO>
(Model.ScoreJson);

var candidate = Model.Candidate;

double percent = score.MaxScore > 0
? Math.Round(((double)score.TotalScore / score.MaxScore) * 100,2)
: 0;
}

<h3 class="fw-bold text-primary mb-3">

Assessment Result — @candidate.FullName

</h3>



<!-- Candidate info -->

<div class="card shadow-sm mb-3">

<div class="card-body">

<div class="row g-3 align-items-center">

<div class="col-12 col-md-3 text-center">

<img src="@candidate.PhotoFilePath"
class="candidate-img"/>

</div>


<div class="col-12 col-md-9">

<div class="row small">

<div class="col-6">
<b>Name</b><br/>
@candidate.FullName
</div>

<div class="col-6">
<b>Gender</b><br/>
@candidate.Gender
</div>

<div class="col-6 mt-2">
<b>DOB</b><br/>
@candidate.DOB.ToString("dd MMM yyyy")
</div>

<div class="col-6 mt-2">
<b>Education</b><br/>
@candidate.Education
</div>

<div class="col-12 mt-2">
<b>Marital Status</b><br/>
@candidate.MaritalStatus
</div>

</div>

</div>

</div>

</div>

</div>



<!-- score -->

<div class="alert alert-primary">

<b>Total Score:</b>

@score.TotalScore / @score.MaxScore

&nbsp;&nbsp;

<b>Percentage:</b>

@percent %

</div>



<!-- charts -->

<div class="row g-3 mb-3">

<div class="col-12 col-md-6">

<div class="card shadow-sm">

<div class="card-body">

<canvas id="barChart"></canvas>

</div>

</div>

</div>


<div class="col-12 col-md-6">

<div class="card shadow-sm">

<div class="card-body">

<canvas id="doughnutChart"></canvas>

</div>

</div>

</div>

</div>



<!-- recommendations -->

@if(recommendations?.Any()==true)
{

<h5 class="fw-bold text-primary">

🎯 Recommendations

</h5>

@foreach(var r in recommendations)
{

<div class="card mb-2 shadow-sm">

<div class="card-body">

<b>@r.Key</b>

<ul class="small mb-0">

@foreach(var rec in r.Value)
{

<li>@rec</li>

}

</ul>

</div>

</div>

}

}



<!-- section results -->

@foreach(var sec in sections)
{

<h5 class="fw-bold text-info mt-4">

@sec.Category

</h5>



<div class="table-responsive">

<table class="table table-bordered small">

<thead class="table-dark">

<tr>

<th>ID</th>

<th>Question</th>

<th>Answer</th>

<th>Score</th>

<th>Evidence</th>

</tr>

</thead>


<tbody>

@foreach(var q in sec.Questions)
{

saved.TryGetValue($"ANS_{q.Id}",out string ans);

saved.TryGetValue($"SCORE_{q.Id}",out string scr);

var files = saved
.Where(x=>x.Key.StartsWith($"FILE_{q.Id}"))
.Select(x=>x.Value)
.ToList();


<tr>

<td>@q.Id</td>

<td>@q.Text</td>

<td>@(ans ?? "-")</td>

<td>@(scr ?? "0")</td>


<td>

@if(files.Any())
{

foreach(var f in files)
{

<a href="/uploads/@f"
target="_blank"
class="btn btn-outline-primary btn-sm mb-1">

View

</a>

}

}
else
{

<span class="text-muted">

—

</span>

}

</td>

</tr>

}

</tbody>

</table>

</div>

}



<!-- summary -->

<div class="alert alert-secondary mt-3">

<b>Summary</b>

<p class="mb-0">

@ViewBag.Summary

</p>

</div>



<!-- pdf -->

<form method="post"
action="/Assessments/ExportReportPdf/@Model.Id">

<input type="hidden"
id="barChartImage"
name="barChartImage"/>

<input type="hidden"
id="doughnutChartImage"
name="doughnutChartImage"/>


<button class="btn btn-primary w-100">

📄 Download PDF

</button>

</form>



<style>

.candidate-img
{
width:130px;
height:150px;
object-fit:cover;
border-radius:10px;
border:1px solid #e5e7eb;
}


.card
{
border-radius:12px;
}


table td
{
vertical-align:middle;
}


@media(max-width:768px){

.candidate-img
{
width:100px;
height:120px;
}

}

</style>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const labels =
@Html.Raw(Json.Serialize(score.SectionScores.Keys));

const values =
@Html.Raw(Json.Serialize(score.SectionScores.Values));

const total=@score.TotalScore;

const remaining=@score.MaxScore-total;


new Chart(document.getElementById("barChart"),{

type:"bar",

data:{
labels,
datasets:[{
label:"Section Score",
data:values
}]
}

});


new Chart(document.getElementById("doughnutChart"),{

type:"doughnut",

data:{
labels:["Achieved","Remaining"],
datasets:[{
data:[total,remaining]
}]
}

});

</script>
