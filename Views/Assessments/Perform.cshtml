@using CAT.AID.Models
@using CAT.AID.Models.DTO
@model Assessment

@{
    var sections = ViewBag.Sections as List<AssessmentSection> ?? new();

    var saved =
    string.IsNullOrWhiteSpace(Model.AssessmentResultJson)
    ? new Dictionary<string, string>()
    : System.Text.Json.JsonSerializer.Deserialize<Dictionary<string,string>>
      (Model.AssessmentResultJson)!;

    bool editable = Model.IsEditableByAssessor;
}

<h3 class="fw-bold mb-2">
Assessment – @Model.Candidate.FullName
</h3>


<!-- progress -->
<div class="progress mb-3">
<div id="progressBar" class="progress-bar"></div>
</div>


<form asp-action="Perform"
      asp-route-id="@Model.Id"
      method="post">


<!-- TABS -->
<div class="tab-scroll">

<ul class="nav nav-pills flex-nowrap">

@for (int i = 0; i < sections.Count; i++)
{

<li class="me-1">

<button type="button"
class="tab-btn @(i==0?"active":"")"
data-bs-toggle="tab"
data-bs-target="#tab-@i">

@sections[i].Category

</button>

</li>

}

<li>

<button type="button"
class="tab-btn"
data-bs-toggle="tab"
data-bs-target="#tab-summary">

Summary

</button>

</li>

</ul>

</div>



<div class="tab-content mt-2">


@for (int i = 0; i < sections.Count; i++)
{

var sec = sections[i];

string sectionCommentKey = $"SECTION_COMMENT_{i}";

saved.TryGetValue(sectionCommentKey,out var savedSectionComment);


<div class="tab-pane fade @(i==0?"show active":"")"
     id="tab-@i">


@foreach (var q in sec.Questions)
{

string qId = q.Id.ToString();

string ansKey = $"ANS_{qId}";
string scrKey = $"SCORE_{qId}";

saved.TryGetValue(ansKey,out var savedAns);
saved.TryGetValue(scrKey,out var savedScore);


<div class="question-card">


<div class="q-text">

@q.Text

</div>


<select class="form-select"
name="@ansKey"
data-id="@qId"
@(editable?"":"disabled")>

<option value="">--</option>

<option value="0" selected="@(savedAns=="0")">
Dependent
</option>

<option value="1" selected="@(savedAns=="1")">
Physical Prompt
</option>

<option value="2" selected="@(savedAns=="2")">
Verbal Prompt
</option>

<option value="3" selected="@(savedAns=="3")">
Independent
</option>

</select>


<input type="hidden"
id="score_@qId"
name="@scrKey"
value="@(savedScore??"0")"
class="score-input"/>

</div>

}


<textarea name="@sectionCommentKey"
class="form-control mt-2"
placeholder="Section comments"
rows="2"
@(editable?"":"readonly")>

@savedSectionComment

</textarea>


</div>

}



<!-- SUMMARY -->

<div class="tab-pane fade"
     id="tab-summary">


<textarea name="SUMMARY_COMMENTS"
class="form-control"
rows="3"
placeholder="Overall summary"
@(editable?"":"readonly")>

@(saved.GetValueOrDefault("SUMMARY_COMMENTS"))

</textarea>


<div class="summary-box mt-2">

Total:
<span id="totalScore"></span>

/

<span id="maxScore"></span>

|

<span id="percentScore"></span>

</div>


</div>


</div>



<!-- FOOTER BUTTONS -->

<div class="footer-bar">

@if(editable)
{

<button class="btn btn-warning me-2"
name="actionType"
value="save">

Save

</button>


<button class="btn btn-primary"
name="actionType"
value="submit">

Submit

</button>

}
else
{

<button class="btn btn-secondary">

Locked

</button>

}

</div>


</form>



<style>

/* tabs scroll */
.tab-scroll{
overflow-x:auto;
white-space:nowrap;
padding-bottom:5px;
}


/* tab button */
.tab-btn{
border:none;
background:#e2e8f0;
padding:6px 14px;
border-radius:20px;
font-weight:600;
font-size:13px;
}

.tab-btn.active{
background:#2563eb;
color:white;
}


/* question card */
.question-card{
border:1px solid #e5e7eb;
border-radius:10px;
padding:10px;
margin-bottom:8px;
background:white;
}


.q-text{
font-weight:600;
font-size:14px;
margin-bottom:5px;
}


/* summary */
.summary-box{
background:#f8fafc;
padding:10px;
border-radius:8px;
font-weight:600;
}


/* sticky footer */
.footer-bar{

position:sticky;

bottom:0;

background:white;

padding:10px;

border-top:1px solid #e5e7eb;

text-align:right;

margin-top:15px;

}


/* mobile spacing */
@media(max-width:768px){

.footer-bar{

text-align:center;

}

.tab-btn{

font-size:12px;

padding:6px 10px;

}

}


</style>
