@using Microsoft.AspNetCore.Identity
@using CAT.AID.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>

<html>

<head>

<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>CVAT</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


<style>

:root{
--primary:#0b5ed7;
--primary-soft:#edf4ff;
--dark:#0f172a;
--bg:#f6f8fc;
--radius:18px;
}

body{
font-family:Poppins;
background:var(--bg);
margin:0;
}


/* HEADER */

.topbar{
height:70px;
background:white;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 30px;
box-shadow:0 4px 18px rgba(0,0,0,.05);
z-index:100;
position:sticky;
top:0;
}

.brand{
font-weight:700;
color:var(--dark);
font-size:18px;
}


/* LAYOUT */

.layout{
display:flex;
}


/* SIDEBAR */

.sidebar{

width:240px;
min-height:100vh;
background:linear-gradient(180deg,#0b5ed7,#2563eb);

padding:25px 15px;
color:white;
position:sticky;
top:70px;
}


.sidebar .nav-link{

color:white;
padding:12px 16px;
border-radius:12px;
font-weight:500;
margin-bottom:8px;
transition:.2s;

}


.sidebar .nav-link:hover{

background:rgba(255,255,255,.15);
transform:translateX(3px);

}


.sidebar .active{

background:white;
color:var(--primary) !important;
font-weight:600;

}


/* CONTENT */

.content{

flex:1;
padding:30px;

}


.page-card{

background:white;
padding:30px;
border-radius:var(--radius);
box-shadow:0 15px 45px rgba(0,0,0,.05);

}


/* USER BADGE */

.user-badge{

background:var(--primary-soft);
padding:6px 12px;
border-radius:20px;
font-size:13px;
font-weight:600;

}


/* FOOTER */

.footer{

text-align:center;
padding:20px;
color:#64748b;
font-size:13px;

}


/* MOBILE */

@@media(max-width:900px){

.sidebar{

width:70px;
padding:20px 8px;

}

.sidebar span{

display:none;

}

}

</style>

</head>



<body>



<!-- TOP BAR -->

<div class="topbar">

<div class="brand">

CVAT – Vocational Assessment

</div>

<div>

@if(SignInManager.IsSignedIn(User))
{

<span class="user-badge">

@User.Identity?.Name

</span>

}

</div>

</div>



<div class="layout">



<!-- SIDEBAR -->

<div class="sidebar">

@if(SignInManager.IsSignedIn(User))
{

@if(User.IsInRole("Admin"))
{

<a class="nav-link" href="/Dashboard">

Dashboard

</a>


<a class="nav-link" href="/Admin/Users">

Users

</a>


<a class="nav-link" href="/QuestionBank/index">

Question Bank

</a>

}


@if(User.IsInRole("LeadAssessor"))
{

<a class="nav-link" href="/Dashboard">

Dashboard

</a>


<a class="nav-link" href="/Candidates">

Candidates

</a>


<a class="nav-link" href="/Assessments/ReviewQueue">

Review Queue

</a>

}


@if(User.IsInRole("Assessor") || User.IsInRole("LeadAssessor"))
{

<a class="nav-link" href="/Assessments/MyTasks">

My Tasks

</a>

}


<a class="nav-link" href="/Support/FAQ">

FAQ

</a>


<a class="nav-link" href="/Support/Help">

Help

</a>


<form asp-controller="Account"
asp-action="Logout"
method="post">

@Html.AntiForgeryToken()

<button class="nav-link text-start w-100 border-0 bg-transparent">

Logout

</button>

</form>

}

</div>



<!-- PAGE CONTENT -->

<div class="content">

<div class="page-card">

@RenderBody()

</div>


<div class="footer">

© @DateTime.Now.Year NIEPID

</div>


</div>



</div>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required:false)

</body>

</html>
