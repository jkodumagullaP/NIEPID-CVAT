@using Microsoft.AspNetCore.Identity
@using CAT.AID.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>

<html>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<link rel="stylesheet" href="~/css/theme-overrides.css">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>CVAT – Comprehensive Vocational Assessment Tool</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>

        /* COLOR SYSTEM */

        :root {
            --primary: #0b5ed7;
            --primary-soft: #e8f0fe;
            --secondary: #1e293b;
            --accent: #ffc107;
            --bg: #f4f7fb;
            --card-radius: 18px;
        }


        /* GLOBAL */

        body {
            font-family: 'Segoe UI',system-ui;
            background: var(--bg);
            color: #1e293b;
            margin: 0;
        }


        /* HEADER */

        .brand-header {
            background: white;
            padding: 15px 0;
            box-shadow: 0 4px 20px rgba(0,0,0,.06);
            border-bottom: 1px solid #eef2f7;
        }


        .brand-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--secondary);
        }


        .brand-sub {
            font-size: 13px;
            color: #6b7280;
        }


        .header-logo {
            transition: .3s;
        }


            .header-logo:hover {
                transform: scale(1.05);
            }


        /* NAVBAR */

        .navbar {
            background: linear-gradient(90deg,#0b5ed7,#2563eb);
            box-shadow: 0 8px 25px rgba(0,0,0,.08);
        }


        .nav-link {
            color: white !important;
            font-weight: 600;
            padding: 9px 16px;
            border-radius: 10px;
            transition: .2s;
        }


            .nav-link:hover {
                background: rgba(255,255,255,.18);
            }


        .dropdown-menu {
            border-radius: 12px;
            box-shadow: 0 15px 40px rgba(0,0,0,.12);
        }


        /* PAGE CONTAINER */

        .content-wrapper {
            margin-top: 30px;
            margin-bottom: 40px;
            animation: fadeIn .35s ease-in-out;
        }


        .page-card {
            background: white;
            padding: 30px;
            border-radius: var(--card-radius);
            box-shadow: 0 15px 45px rgba(0,0,0,.05);
        }


        /* BUTTONS */

        .btn {
            border-radius: 10px;
            padding: 8px 18px;
            font-weight: 600;
        }


        .btn-primary {
            background: linear-gradient(90deg,#0b5ed7,#2563eb);
            border: none;
        }


            .btn-primary:hover {
                opacity: .9;
            }


        /* TABLE */

        .table {
            border-radius: 12px;
            overflow: hidden;
        }


            .table thead {
                background: #f1f5f9;
                font-weight: 600;
            }


        .table-hover tbody tr:hover {
            background: #f8fafc;
        }


        /* BADGES */

        .badge {
            padding: 6px 10px;
            border-radius: 8px;
            font-weight: 600;
        }


        /* FOOTER */

        .footer {
            background: white;
            padding: 20px;
            text-align: center;
            font-size: 13px;
            color: #64748b;
            border-top: 1px solid #e5e7eb;
        }


        /* ANIMATION FIX FOR RAZOR */

        @@keyframes fadeIn {

            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

    </style>


<link rel="stylesheet" href="~/css/navy-sidebar.css">
</head>



<body>


    <!-- HEADER -->

    <div class="brand-header">

        <div class="container d-flex align-items-center justify-content-between">

            <img src="/Images/20240912282747915.png" height="65" class="header-logo" />

            <div class="text-center">

                <div class="brand-title">
                    CVAT – Comprehensive Vocational Assessment Tool
                </div>

                <div class="brand-sub">
                    Vocational Evaluation • Skill Assessment • Career Planning
                </div>

            </div>

            <img src="/Images/202409121913074416.png" height="65" class="header-logo" />

        </div>

    </div>



    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg">

        <div class="container">

            <button class="navbar-toggler bg-light"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav">

                <span class="navbar-toggler-icon"></span>

            </button>


            <div class="collapse navbar-collapse" id="mainNav">

                <ul class="navbar-nav me-auto gap-2">

                    @if (SignInManager.IsSignedIn(User))
                    {

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Dashboard">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Users">Users</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/QuestionBank/index">Question Bank</a>
                            </li>
                        }

                        @if (User.IsInRole("LeadAssessor"))
                        {

                            <li class="nav-item">
                                <a class="nav-link" href="/Dashboard">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Candidates">Candidates</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/Assessments/ReviewQueue">
                                    Review Queue
                                </a>
                            </li>

                        }


                        @if (User.IsInRole("Assessor") || User.IsInRole("LeadAssessor"))
                        {

                            <li class="nav-item">
                                <a class="nav-link" href="/Assessments/MyTasks">
                                    Assessments
                                </a>
                            </li>

                        }


                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                               data-bs-toggle="dropdown">

                                Support

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item" href="/Support/FAQ">
                                        FAQs
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Support/Help">
                                        Help
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" href="/Support/Contact">
                                        Contact
                                    </a>
                                </li>

                            </ul>

                        </li>

                    }

                </ul>


                <ul class="navbar-nav ms-auto">

                    @if (SignInManager.IsSignedIn(User))
                    {

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle"
                               data-bs-toggle="dropdown">

                                @User.Identity?.Name

                            </a>


                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>

                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="dropdown-item text-danger fw-bold">

                                            Logout

                                        </button>

                                    </form>

                                </li>

                            </ul>

                        </li>

                    }

                </ul>

            </div>

        </div>

    </nav>



    <!-- CONTENT -->

    <div class="container content-wrapper">

        <div class="page-card">

            @RenderBody()

        </div>

    </div>



    <!-- FOOTER -->

    <div class="footer">

        © @DateTime.Now.Year NIEPID
        Manovikas Nagar, Secunderabad – 500009

    </div>  



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>
