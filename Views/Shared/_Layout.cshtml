@using Microsoft.AspNetCore.Identity
@using CAT.AID.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>

<html>

<head>

<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>

<title>CVAT</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600;700&display=swap" rel="stylesheet">

<style>

:root{
--primary:#0b5ed7;
--primary-soft:#edf4ff;
--dark:#0f172a;
--bg:#f6f8fc;
--radius:18px;
}

body{
font-family:Poppins;
background:var(--bg);
margin:0;
}


/* TOPBAR */

.topbar{

height:65px;
background:white;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 18px;
box-shadow:0 4px 18px rgba(0,0,0,.05);
position:sticky;
top:0;
z-index:1000;

}

.brand{

font-weight:600;
font-size:16px;

}


/* HAMBURGER */

.menu-btn{

border:none;
background:none;
font-size:22px;

}


/* LAYOUT */

.layout{

display:flex;

}


/* SIDEBAR */

.sidebar{

width:240px;
min-height:100vh;
background:linear-gradient(180deg,#0b5ed7,#2563eb);
padding:25px 15px;
color:white;
transition:.3s;

}

.sidebar a{

display:block;
color:white;
padding:12px 16px;
border-radius:12px;
margin-bottom:6px;
text-decoration:none;
font-weight:500;

}

.sidebar a:hover{

background:rgba(255,255,255,.18);

}


/* CONTENT */

.content{

flex:1;
padding:25px;

}


.page-card{

background:white;
padding:25px;
border-radius:var(--radius);
box-shadow:0 15px 45px rgba(0,0,0,.05);

}


/* MOBILE */

@@media(max-width:900px){

.sidebar{

position:fixed;
left:-260px;
top:65px;
height:100%;
z-index:999;
width:240px;

}

.sidebar.show{

left:0;

}

.content{

padding:15px;

}

}


/* FOOTER */

.footer{

text-align:center;
font-size:13px;
color:#64748b;
padding:15px;

}

</style>

</head>



<body>



<!-- TOPBAR -->

<div class="topbar">

<button class="menu-btn" onclick="toggleMenu()">

☰

</button>


<div class="brand">

CVAT

</div>


@if(SignInManager.IsSignedIn(User))
{

<div class="small">

@User.Identity?.Name

</div>

}

</div>



<div class="layout">



<!-- SIDEBAR -->

<div id="sidebar" class="sidebar">

@if(SignInManager.IsSignedIn(User))
{

@if(User.IsInRole("Admin"))
{

<a href="/Dashboard">Dashboard</a>

<a href="/Admin/Users">Users</a>

<a href="/QuestionBank/index">Question Bank</a>

}


@if(User.IsInRole("LeadAssessor"))
{

<a href="/Dashboard">Dashboard</a>

<a href="/Candidates">Candidates</a>

<a href="/Assessments/ReviewQueue">Review Queue</a>

}


@if(User.IsInRole("Assessor") || User.IsInRole("LeadAssessor"))
{

<a href="/Assessments/MyTasks">My Tasks</a>

}


<a href="/Support/FAQ">FAQ</a>

<a href="/Support/Help">Help</a>


<form asp-controller="Account"
asp-action="Logout"
method="post">

@Html.AntiForgeryToken()

<button class="nav-link border-0 bg-transparent text-start text-white">

Logout

</button>

</form>

}

</div>



<!-- CONTENT -->

<div class="content">

<div class="page-card">

@RenderBody()

</div>


<div class="footer">

© @DateTime.Now.Year NIEPID

</div>

</div>



</div>



<script>

function toggleMenu(){

document
.getElementById("sidebar")
.classList
.toggle("show");

}

</script>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required:false)

</body>

</html>
